# ABOUTME: Example environment configuration for pleasehold self-hosting.
# ABOUTME: Copy to .env and fill in required values before running docker compose up.

# ============================================================
# pleasehold.dev - Environment Configuration
# ============================================================
# Copy this file to .env and fill in required values.
# Required values are marked with (REQUIRED).
# ============================================================

# --- Database ---
# Only needed for local development (without Docker).
# Docker Compose constructs DATABASE_URL from POSTGRES_* vars below.
# DATABASE_URL=postgresql://pleasehold:pleasehold@localhost:5434/pleasehold

# PostgreSQL credentials (used by Docker Compose)
POSTGRES_DB=pleasehold
POSTGRES_USER=pleasehold
POSTGRES_PASSWORD=changeme            # (REQUIRED) Change this to a secure password

# --- Authentication ---
BETTER_AUTH_SECRET=                    # (REQUIRED) Random 32+ character string for session signing

# --- URLs ---
# Public-facing URLs for your deployment
API_URL=http://localhost:3001          # URL where the API is accessible
WEB_URL=http://localhost:8080          # URL where the dashboard is accessible

# --- Ports ---
# Host ports for Docker port mapping
API_PORT=3001
WEB_PORT=8080

# --- OAuth Providers (optional) ---
# Leave blank to disable OAuth login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email / Resend (optional) ---
# Required for email notifications and double opt-in verification
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com
