{
	"name": "@pleasehold/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsup",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"test": "vitest run"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.999.0",
		"@aws-sdk/s3-request-presigner": "^3.999.0",
		"@hono/node-server": "^1.14.0",
		"@hono/trpc-server": "^0.4.2",
		"@hono/zod-openapi": "^0.19.10",
		"@pleasehold/auth": "workspace:*",
		"@pleasehold/db": "workspace:*",
		"@pleasehold/trpc": "workspace:*",
		"@scalar/hono-api-reference": "^0.9.45",
		"better-auth": "^1.4.19",
		"bullmq": "^5",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.12.2",
		"hono-rate-limiter": "^0.5.3",
		"ioredis": "^5",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"postgres": "^3.4.8",
		"tsup": "^8.3.5",
