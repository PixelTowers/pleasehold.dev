---

<section class="px-6 py-24 md:py-32">
	<div class="mx-auto max-w-[1080px] text-center">
		<h2 class="text-3xl font-semibold tracking-tight text-text-primary sm:text-4xl" style="text-wrap: balance;">
			What you get.
		</h2>

		<!-- Hero features — two large cards -->
		<div class="mt-14 grid gap-4 sm:grid-cols-2">
			{heroFeatures.map((feature) => (
				<div class="rounded-xl bg-surface p-8 text-left">
					<svg class="mb-4 h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
						<Fragment set:html={feature.icon} />
					</svg>
					<h3 class="text-base font-medium text-text-primary">{feature.title}</h3>
					<p class="mt-2 text-sm leading-relaxed text-text-tertiary">{feature.description}</p>
				</div>
			))}
		</div>

		<!-- Remaining features — 3-col compact grid -->
		<div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{features.map((feature) => (
				<div class="rounded-xl border border-border p-6 text-left">
					<svg class="mb-3 h-5 w-5 text-text-quaternary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
						<Fragment set:html={feature.icon} />
					</svg>
					<h3 class="text-sm font-medium text-text-primary">{feature.title}</h3>
					<p class="mt-1.5 text-[13px] leading-relaxed text-text-tertiary">{feature.description}</p>
				</div>
			))}
		</div>
	</div>
</section>
