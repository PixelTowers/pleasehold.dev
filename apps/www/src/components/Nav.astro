---
const links = [
	{ label: "Docs", href: "https://app.pleasehold.dev/docs" },
	{ label: "GitHub", href: "https://github.com/PixelTowers/pleasehold.dev" },
	{ label: "Pricing", href: "/#pricing" },
];
---

<nav class="fixed top-0 z-50 w-full border-b border-border bg-page/80 backdrop-blur-lg">
	<div class="mx-auto flex h-14 max-w-[1080px] items-center justify-between px-6">
		<a href="/" class="flex items-center gap-2.5">
			<svg viewBox="0 0 32 32" class="h-5 w-5" aria-hidden="true">
				<rect x="1" y="1" width="30" height="30" rx="6" fill="#0d9488"/>
				<rect x="10" y="8" width="3.5" height="16" rx="1.75" fill="white"/>
				<rect x="18.5" y="8" width="3.5" height="16" rx="1.75" fill="white"/>
			</svg>
			<span class="text-sm font-medium text-text-primary">pleasehold.dev</span>
		</a>
		<div class="flex items-center gap-6">
			{links.map((link) => (
				<a
					href={link.href}
					class="hidden text-sm text-text-tertiary transition-colors hover:text-text-primary sm:block"
				>
					{link.label}
				</a>
			))}
			<a
				href="https://app.pleasehold.dev"
				class="rounded-full bg-accent px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
			>
				Go to app
			</a>
		</div>
	</div>
</nav>
