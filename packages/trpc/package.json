{
	"name": "@pleasehold/trpc",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch --no-dts",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@pleasehold/auth": "workspace:*",
		"@pleasehold/db": "workspace:*",
		"@trpc/server": "^11.10.0",
		"drizzle-orm": "^0.45.1",
		"sanitize-html": "^2.17.1",
		"superjson": "^2.2.2",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^25.3.1",
		"@types/sanitize-html": "^2.16.0",
		"tsup": "^8.3.5",
		"typescript": "~5.7.3"
	}
}
