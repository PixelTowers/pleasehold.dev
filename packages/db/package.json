{
	"name": "@pleasehold/db",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch --no-dts",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"postgres": "^3.4.7"
	},
	"devDependencies": {
		"drizzle-kit": "^0.31.9",
		"tsup": "^8.3.5",
		"typescript": "~5.7.3"
	}
}
