{
	"name": "pleasehold",
	"private": true,
	"packageManager": "pnpm@10.30.1",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "dotenv -e .env -- turbo dev",
		"build": "turbo build",
		"lint": "turbo lint",
		"typecheck": "turbo typecheck",
		"db:generate": "turbo db:generate",
		"db:migrate": "turbo db:migrate",
		"clean": "turbo clean && rm -rf node_modules",
		"prepare": "husky"
	},
	"pnpm": {
		"//overrides": "Dual zod: v4 global, v3 for @tanstack/router-* and astro (no v4 support yet). See scripts/patch-pruned-lockfile.mjs for Docker implications.",
		"overrides": {
			"zod": "^4.3.6",
			"@tanstack/router-generator>zod": "^3.25.76",
			"@tanstack/router-plugin>zod": "^3.25.76",
			"astro>zod": "^3.25.76"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"dotenv-cli": "^11.0.0",
		"husky": "^9.1.7",
		"turbo": "2.4.4",
		"typescript": "~5.7.3"
	}
}
